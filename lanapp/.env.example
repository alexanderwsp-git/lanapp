PORT=4001
NODE_ENV=development
DATABASE_URL=postgres://admin:adm1n*@localhost:5434/webapp
DATABASE_SCHEMA=lanapp

# Local dev: bypass JWT verification (pair with NEXT_PUBLIC_SKIP_AUTH=true in lanapp-ui)
SKIP_AUTH=true

# Cognito (production — set SKIP_AUTH=false; same pool as lanapp-ui)
# COGNITO_USER_POOL_ID=us-east-1_xxxxx
# COGNITO_CLIENT_ID=
# COGNITO_APP_GROUP_PREFIX=lanapp_
