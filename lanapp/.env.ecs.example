# Copy these into ecs/.env_backend (see create-backend.sh)

PORT=3000
NODE_ENV=production
DATABASE_URL=postgres://user_lanapp:<password>@<rds-host>:5432/lanappdb
DATABASE_SCHEMA=lanapp
DATABASE_SSL=true
AWS_S3_BUCKET=mexp-imagenes-lanapp-unique-id
API_PREFIX=/api/v1/lanapp

# Local dev: SKIP_AUTH=true — Production with Cognito:
SKIP_AUTH=false
COGNITO_USER_POOL_ID=<terraform output cognito_user_pool_id>
COGNITO_CLIENT_ID=<terraform output cognito_client_id>
