# Copy these into the ECS task definition (environment + secrets).
# Locally, the same keys go in lanapp/.env (see .env.example).

PORT=3000
NODE_ENV=production
DATABASE_URL=postgres://user_lanapp:<password>@<rds-host>:5432/lanappdb
DATABASE_SCHEMA=lanapp
AWS_S3_BUCKET=mexp-imagenes-lanapp-unique-id
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.lanapp.sheep
