# Browser calls same-origin /api/v1/* — Next rewrites proxy to lanapp API
NEXT_PUBLIC_API_PREFIX=/api/v1

# Server-side rewrite target (local dev)
LANAPP_SERVICE_URL=http://localhost:4001 # or https://lanapp-api.myxperiences.org
AUTH_SERVICE_URL=http://localhost:4000

# --- Auth (Cognito, invite-only) ---
# Local dev bypass: no login required; API also uses SKIP_AUTH in lanapp/.env
NEXT_PUBLIC_SKIP_AUTH=true

# Real Cognito (set NEXT_PUBLIC_SKIP_AUTH=false and SKIP_AUTH=false in lanapp/.env):
# AWS_REGION=us-east-1
# COGNITO_USER_POOL_ID=<terraform output>
# COGNITO_CLIENT_ID=<terraform output cognito_client_id>
# COGNITO_CLIENT_SECRET=<terraform output cognito_client_secret>
# No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY needed for login/forgot/reset.
# Invitar usuarios en prod usa el ECS task role (mexp-lanapp-front-task-role).
# Invitar en local: `aws configure` o AWS_PROFILE=tu-perfil (ver docs/AUTH.md)

# Mock layer — set USE_MOCKS=true for offline / v0-style dev (restart dev server after change)
# NEXT_PUBLIC_USE_MOCKS=true
# NEXT_PUBLIC_MOCK_SEED=42
# NEXT_PUBLIC_MOCK_EXTRA_SHEEP=40
# NEXT_PUBLIC_MOCK_WEIGHTS_PER_SHEEP=2

# PORT=3000
# NODE_ENV=production
# HOSTNAME=0.0.0.0
