# Browser calls same-origin /api/v1/* — Next rewrites proxy to backend (see next.config.mjs)
NEXT_PUBLIC_API_PREFIX=/api/v1

# Server-side rewrite targets (local dev)
LANAPP_SERVICE_URL=http://localhost:4001
AUTH_SERVICE_URL=http://localhost:4000

# Local dev: lanapp runs with SKIP_AUTH=true — no login required
NEXT_PUBLIC_SKIP_AUTH=true

# Production Auth0 (when wired)
# NEXT_PUBLIC_AUTH0_DOMAIN=
# NEXT_PUBLIC_AUTH0_CLIENT_ID=
# NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.lanapp.sheep
