# Baked into the image at docker build (build-args):
LANAPP_SERVICE_URL=https://lanapp-api.myxperiences.org
NEXT_PUBLIC_API_PREFIX=/api/v1

# AUTH_SERVICE_URL — not used yet (login is a stub; auth service not deployed)

# ECS task definition runtime:
PORT=3000
NODE_ENV=production
HOSTNAME=0.0.0.0

# Auth is bypassed on the API (SKIP_AUTH=true on lanapp-back task), not on the UI.
